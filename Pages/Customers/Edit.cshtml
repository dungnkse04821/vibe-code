@page
@model OMS.Pages.Customers.EditModel
@{
    ViewData["Title"] = "Chỉnh sửa Khách hàng";
}

<div class="glass-card" style="max-width: 800px; margin: 0 auto;">
    <div class="mb-4">
        <h1 class="page-title">Chỉnh sửa Khách hàng</h1>
        <p style="color: var(--text-muted); margin: 0; font-size: 0.9rem;">Cập nhật thông tin chi tiết cho khách hàng <strong style="color: #00f2fe;">@Model.Customer.Id</strong></p>
    </div>

    <form method="post">
        <!-- Hidden input for ID -->
        <input type="hidden" asp-for="Customer.Id" />

        <div class="grid-2">
            <div class="form-group">
                <label class="form-label">Mã Khách hàng</label>
                <input class="form-input" value="@Model.Customer.Id" disabled style="opacity: 0.6; cursor: not-allowed; font-family: monospace; color: #00f2fe;" />
            </div>

            <div class="form-group">
                <label asp-for="Customer.FullName" class="form-label"></label>
                <input asp-for="Customer.FullName" class="form-input" placeholder="Nhập họ và tên..." />
                <span asp-validation-for="Customer.FullName" class="text-danger"></span>
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Customer.PhoneNumber" class="form-label"></label>
                <input asp-for="Customer.PhoneNumber" class="form-input" placeholder="Nhập số điện thoại..." />
                <span asp-validation-for="Customer.PhoneNumber" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Customer.Reference" class="form-label"></label>
                <input asp-for="Customer.Reference" class="form-input" placeholder="Facebook Link, người giới thiệu..." />
                <span asp-validation-for="Customer.Reference" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Customer.Address" class="form-label"></label>
            <input asp-for="Customer.Address" class="form-input" placeholder="Nhập địa chỉ đầy đủ..." />
            <span asp-validation-for="Customer.Address" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Customer.Note" class="form-label"></label>
            <textarea asp-for="Customer.Note" class="form-input" rows="3" placeholder="Nhập ghi chú (nếu có)..." style="resize: vertical;"></textarea>
            <span asp-validation-for="Customer.Note" class="text-danger"></span>
        </div>

        <div style="display: flex; gap: 15px; justify-content: flex-end; margin-top: 30px; flex-wrap: wrap;">
            <a href="/Customers" class="btn-secondary-premium">
                Hủy
            </a>
            <button type="submit" class="btn-premium">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 18px; height: 18px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
                </svg>
                Cập nhật
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
