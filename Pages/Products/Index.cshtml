@page
@model VibeCode.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
        <div>
            <h1 class="page-title">Quản lý Sản phẩm</h1>
            <p style="color: var(--text-muted); margin: 0; font-size: 0.9rem;">Danh sách SKU sản phẩm, giá nhập, giá bán và kho chứa</p>
        </div>
        <a href="/Products/Create" class="btn-premium">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 18px; height: 18px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Thêm sản phẩm
        </a>
    </div>

    <!-- Filter Bar -->
    <form method="get" class="filter-bar" style="margin-bottom: 24px;">
        <div class="filter-item" style="display: flex; gap: 10px;">
            <input type="text" asp-for="SearchQuery" class="form-input" placeholder="Tìm kiếm theo mã SKU, tên, danh mục, nguồn hàng..." style="flex-grow: 1;" />
            <button type="submit" class="btn-secondary-premium" style="padding: 12px 20px;">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 18px; height: 18px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.637 10.637z" />
                </svg>
                Tìm
            </button>
            @if (!string.IsNullOrEmpty(Model.SearchQuery))
            {
                <a href="/Products" class="btn-secondary-premium" style="padding: 12px 20px; display: inline-flex; align-items: center; justify-content: center;">Đặt lại</a>
            }
        </div>
    </form>

    <!-- Desktop View (Table) -->
    <div class="d-none d-md-table table-responsive" style="width: 100%;">
        @if (Model.Products.Count == 0)
        {
            <div style="text-align: center; padding: 40px; color: var(--text-muted);">
                Không tìm thấy sản phẩm nào.
            </div>
        }
        else
        {
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Mã SKU</th>
                        <th>Tên sản phẩm</th>
                        <th>Danh mục</th>
                        <th style="text-align: right;">Giá nhập</th>
                        <th style="text-align: right;">Giá bán</th>
                        <th>Nguồn hàng</th>
                        <th>Kho</th>
                        <th style="text-align: right;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.Products)
                    {
                        <tr>
                            <td style="font-family: monospace; color: #00f2fe; font-weight: 600;">@product.Sku</td>
                            <td style="font-weight: 600;">@product.Name</td>
                            <td><span style="background: rgba(255,255,255,0.05); padding: 4px 8px; border-radius: 4px; font-size: 0.85rem;">@product.Category</span></td>
                            <td style="text-align: right; color: var(--text-muted);">@product.ImportPrice.ToString("N0") ₫</td>
                            <td style="text-align: right; color: #00f2fe; font-weight: 600;">@product.SellingPrice.ToString("N0") ₫</td>
                            <td>@product.Source</td>
                            <td>@product.Warehouse</td>
                            <td>
                                <div class="action-btn-group" style="justify-content: flex-end;">
                                    <a href="/Products/Edit?sku=@product.Sku" class="action-btn edit" title="Sửa">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
                                        </svg>
                                    </a>
                                    <a href="/Products/Delete?sku=@product.Sku" class="action-btn delete" title="Xóa">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-1.8c0-.621-.504-1.125-1.125-1.125h-2.25c-.621 0-1.125.504-1.125 1.125v1.8M8.25 6.75h7.5" />
                                        </svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Mobile View (Cards) -->
    <div class="d-md-none mobile-card-list">
        @if (Model.Products.Count == 0)
        {
            <div style="text-align: center; padding: 40px; color: var(--text-muted);">
                Không tìm thấy sản phẩm nào.
            </div>
        }
        else
        {
            @foreach (var product in Model.Products)
            {
                <div class="mobile-data-card">
                    <div class="mobile-card-header">
                        <span class="mobile-card-title" style="color: #00f2fe;">@product.Name</span>
                        <span style="font-family: monospace; font-size: 0.85rem; font-weight: bold; background: rgba(0, 242, 254, 0.08); padding: 2px 6px; border-radius: 4px; color: #00f2fe;">@product.Sku</span>
                    </div>
                    <div class="mobile-card-body">
                        <div>
                            <span class="mobile-card-label">Danh mục:</span>
                            <span class="mobile-card-value">@product.Category</span>
                        </div>
                        <div>
                            <span class="mobile-card-label">Nguồn hàng:</span>
                            <span class="mobile-card-value">@product.Source</span>
                        </div>
                        <div>
                            <span class="mobile-card-label">Giá nhập:</span>
                            <span class="mobile-card-value" style="color: var(--text-muted);">@product.ImportPrice.ToString("N0") ₫</span>
                        </div>
                        <div>
                            <span class="mobile-card-label">Giá bán:</span>
                            <span class="mobile-card-value" style="color: #00f2fe; font-weight: bold;">@product.SellingPrice.ToString("N0") ₫</span>
                        </div>
                        <div style="grid-column: span 2;">
                            <span class="mobile-card-label">Kho lưu trữ:</span>
                            <span class="mobile-card-value">@product.Warehouse</span>
                        </div>
                    </div>
                    <div class="mobile-card-actions">
                        <a href="/Products/Edit?sku=@product.Sku" class="btn-secondary-premium" style="padding: 6px 12px; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 4px;">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 14px; height: 14px;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
                            </svg>
                            Sửa
                        </a>
                        <a href="/Products/Delete?sku=@product.Sku" class="btn-danger-premium" style="padding: 6px 12px; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 4px;">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 14px; height: 14px;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-1.8c0-.621-.504-1.125-1.125-1.125h-2.25c-.621 0-1.125.504-1.125 1.125v1.8M8.25 6.75h7.5" />
                            </svg>
                            Xóa
                        </a>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    @@media (min-width: 768px) {
        .d-none { display: none !important; }
        .d-md-table { display: table !important; }
        .d-md-none { display: none !important; }
    }
    @@media (max-width: 767.98px) {
        .d-none { display: none !important; }
        .d-md-table { display: none !important; }
        .d-md-none { display: flex !important; }
    }
</style>
