@page
@model OMS.Pages.Products.EditModel
@{
    ViewData["Title"] = "Chỉnh sửa Sản phẩm";
}

<div class="glass-card" style="max-width: 800px; margin: 0 auto;">
    <div class="mb-4">
        <h1 class="page-title">Chỉnh sửa Sản phẩm</h1>
        <p style="color: var(--text-muted); margin: 0; font-size: 0.9rem;">Cập nhật thông tin chi tiết cho sản phẩm <strong style="color: #00f2fe;">@Model.Product.Sku</strong></p>
    </div>

    <form method="post">
        <!-- Hidden input for Sku primary key -->
        <input type="hidden" asp-for="Product.Sku" />

        <div class="grid-2">
            <div class="form-group">
                <label class="form-label">Mã SKU</label>
                <input class="form-input" value="@Model.Product.Sku" disabled style="opacity: 0.6; cursor: not-allowed; font-family: monospace; color: #00f2fe;" />
            </div>

            <div class="form-group">
                <label asp-for="Product.Name" class="form-label"></label>
                <input asp-for="Product.Name" class="form-input" placeholder="Nhập tên sản phẩm..." />
                <span asp-validation-for="Product.Name" class="text-danger"></span>
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Product.Category" class="form-label"></label>
                <input asp-for="Product.Category" class="form-input" placeholder="Ví dụ: Áo thun, Quần jean..." />
                <span asp-validation-for="Product.Category" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Product.Source" class="form-label"></label>
                <input asp-for="Product.Source" class="form-input" placeholder="Ví dụ: Quảng Châu, Taobao..." />
                <span asp-validation-for="Product.Source" class="text-danger"></span>
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Product.ImportPrice" class="form-label"></label>
                <input asp-for="Product.ImportPrice" type="number" step="any" class="form-input" placeholder="Ví dụ: 150000" />
                <span asp-validation-for="Product.ImportPrice" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Product.SellingPrice" class="form-label"></label>
                <input asp-for="Product.SellingPrice" type="number" step="any" class="form-input" placeholder="Ví dụ: 250000" />
                <span asp-validation-for="Product.SellingPrice" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Product.Warehouse" class="form-label"></label>
            <input asp-for="Product.Warehouse" class="form-input" placeholder="Ví dụ: Kho Hà Nội, Kho HCM..." />
            <span asp-validation-for="Product.Warehouse" class="text-danger"></span>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Product.StockQuantity" class="form-label"></label>
                <input asp-for="Product.StockQuantity" type="number" min="0" class="form-input" placeholder="Ví dụ: 50" />
                <span asp-validation-for="Product.StockQuantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Product.LowStockThreshold" class="form-label"></label>
                <input asp-for="Product.LowStockThreshold" type="number" min="0" class="form-input" placeholder="Ví dụ: 5" />
                <span style="font-size: 0.78rem; color: var(--text-muted); display: block; margin-top: 4px;">⚠️ Cảnh báo khi tồn kho ≤ ngưỡng này</span>
            </div>
        </div>

        <div style="display: flex; gap: 15px; justify-content: flex-end; margin-top: 30px; flex-wrap: wrap;">
            <a href="/Products" class="btn-secondary-premium">
                Hủy
            </a>
            <button type="submit" class="btn-premium">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 18px; height: 18px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
                </svg>
                Cập nhật
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
