@page
@model OMS.Pages.Products.CreateModel
@{
    ViewData["Title"] = "Thêm Sản phẩm mới";
}

<div class="glass-card" style="max-width: 800px; margin: 0 auto;">
    <div class="mb-4">
        <h1 class="page-title">Thêm Sản phẩm mới</h1>
        <p style="color: var(--text-muted); margin: 0; font-size: 0.9rem;">Tạo SKU sản phẩm mới, xác lập giá và vị trí lưu trữ kho</p>
    </div>

    <form method="post">
        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Product.Sku" class="form-label">Mã SKU (Viết liền, không dấu)</label>
                <input asp-for="Product.Sku" class="form-input" placeholder="Ví dụ: AO-THUN-01..." style="font-family: monospace; text-transform: uppercase;" />
                <span asp-validation-for="Product.Sku" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Product.Name" class="form-label"></label>
                <input asp-for="Product.Name" class="form-input" placeholder="Nhập tên sản phẩm..." />
                <span asp-validation-for="Product.Name" class="text-danger"></span>
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Product.Category" class="form-label"></label>
                <input asp-for="Product.Category" class="form-input" placeholder="Ví dụ: Áo thun, Quần jean, Giày dép..." />
                <span asp-validation-for="Product.Category" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Product.Source" class="form-label"></label>
                <input asp-for="Product.Source" class="form-input" placeholder="Ví dụ: Quảng Châu, Taobao, Xưởng VN..." />
                <span asp-validation-for="Product.Source" class="text-danger"></span>
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Product.ImportPrice" class="form-label"></label>
                <input asp-for="Product.ImportPrice" type="number" step="any" class="form-input" placeholder="Ví dụ: 150000" />
                <span asp-validation-for="Product.ImportPrice" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Product.SellingPrice" class="form-label"></label>
                <input asp-for="Product.SellingPrice" type="number" step="any" class="form-input" placeholder="Ví dụ: 250000" />
                <span asp-validation-for="Product.SellingPrice" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Product.Warehouse" class="form-label"></label>
            <input asp-for="Product.Warehouse" class="form-input" placeholder="Ví dụ: Kho Hà Nội, Kho HCM, Kho Tổng..." />
            <span asp-validation-for="Product.Warehouse" class="text-danger"></span>
        </div>

        <div style="display: flex; gap: 15px; justify-content: flex-end; margin-top: 30px; flex-wrap: wrap;">
            <a href="/Products" class="btn-secondary-premium">
                Hủy
            </a>
            <button type="submit" class="btn-premium">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 18px; height: 18px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                Lưu sản phẩm
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
