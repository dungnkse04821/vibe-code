@page
@model OMS.Pages.AuditLog.IndexModel
@{
    ViewData["Title"] = "Audit Log — Nhật ký hệ thống";
}

<div class="glass-card">
    <!-- Header -->
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:15px;margin-bottom:1.5rem;">
        <div>
            <h1 class="page-title">🔍 Audit Log</h1>
            <p style="color:var(--text-muted);margin:0;font-size:0.9rem;">
                Nhật ký toàn bộ thao tác CRUD — Đơn hàng · Khách hàng · Sản phẩm
            </p>
        </div>
        <div style="background:rgba(0,242,254,0.06);border:1px solid rgba(0,242,254,0.2);border-radius:10px;padding:10px 18px;text-align:center;">
            <div style="font-size:1.4rem;font-weight:700;color:#00f2fe;">@Model.TotalCount</div>
            <div style="font-size:0.72rem;color:var(--text-muted);">tổng bản ghi</div>
        </div>
    </div>

    <!-- Filters -->
    <form method="get" style="display:flex;flex-wrap:wrap;gap:10px;align-items:flex-end;margin-bottom:20px;">
        <div style="flex:1;min-width:140px;">
            <label style="font-size:0.78rem;color:var(--text-muted);display:block;margin-bottom:5px;">Loại đối tượng</label>
            <select name="FilterEntity" class="form-control" style="width:100%;">
                <option value="">Tất cả</option>
                <option value="Order" selected="@(Model.FilterEntity == "Order")">Đơn hàng</option>
                <option value="Customer" selected="@(Model.FilterEntity == "Customer")">Khách hàng</option>
                <option value="Product" selected="@(Model.FilterEntity == "Product")">Sản phẩm</option>
            </select>
        </div>
        <div style="flex:1;min-width:140px;">
            <label style="font-size:0.78rem;color:var(--text-muted);display:block;margin-bottom:5px;">Thao tác</label>
            <select name="FilterAction" class="form-control" style="width:100%;">
                <option value="">Tất cả</option>
                <option value="Create" selected="@(Model.FilterAction == "Create")">✨ Tạo mới</option>
                <option value="Update" selected="@(Model.FilterAction == "Update")">✏️ Cập nhật</option>
                <option value="Delete" selected="@(Model.FilterAction == "Delete")">🗑️ Xóa</option>
            </select>
        </div>
        <div style="flex:2;min-width:180px;">
            <label style="font-size:0.78rem;color:var(--text-muted);display:block;margin-bottom:5px;">Tìm theo ID</label>
            <input name="FilterId" value="@Model.FilterId" class="form-control" placeholder="Mã đơn / SKU / ID khách hàng..." style="width:100%;" />
        </div>
        <div style="display:flex;gap:8px;">
            <button type="submit" class="btn-primary-premium" style="padding:10px 20px;">Lọc</button>
            <a href="/AuditLog" class="btn-secondary-premium" style="padding:10px 16px;">Xóa lọc</a>
        </div>
    </form>

    <!-- Summary chips -->
    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;">
        @{
            var creates = Model.Logs.Count(l => l.Action == "Create");
            var updates = Model.Logs.Count(l => l.Action == "Update");
            var deletes = Model.Logs.Count(l => l.Action == "Delete");
        }
        <span style="background:rgba(0,242,254,0.1);border:1px solid rgba(0,242,254,0.25);color:#00f2fe;border-radius:20px;padding:4px 14px;font-size:0.8rem;font-weight:600;">✨ @creates Tạo mới</span>
        <span style="background:rgba(247,151,30,0.1);border:1px solid rgba(247,151,30,0.25);color:#f7971e;border-radius:20px;padding:4px 14px;font-size:0.8rem;font-weight:600;">✏️ @updates Cập nhật</span>
        <span style="background:rgba(255,77,77,0.1);border:1px solid rgba(255,77,77,0.25);color:#ff4d4d;border-radius:20px;padding:4px 14px;font-size:0.8rem;font-weight:600;">🗑️ @deletes Xóa</span>
        @if (Model.TotalCount > 200)
        {
            <span style="background:rgba(255,255,255,0.04);border:1px solid var(--border-color);color:var(--text-muted);border-radius:20px;padding:4px 14px;font-size:0.8rem;">Hiển thị 200 / @Model.TotalCount bản ghi mới nhất</span>
        }
    </div>

    <!-- Table -->
    @if (Model.Logs.Count == 0)
    {
        <div style="text-align:center;padding:80px 20px;color:var(--text-muted);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" style="width:56px;height:56px;opacity:0.25;margin:0 auto 16px;display:block;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
            <p>Chưa có bản ghi audit nào phù hợp.</p>
        </div>
    }
    else
    {
        <div style="overflow-x:auto;">
            <table style="width:100%;border-collapse:collapse;">
                <thead>
                    <tr style="border-bottom:1px solid var(--border-color);">
                        <th style="padding:10px 12px;text-align:left;font-size:0.75rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap;">Thời gian</th>
                        <th style="padding:10px 12px;text-align:left;font-size:0.75rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.5px;">Đối tượng</th>
                        <th style="padding:10px 12px;text-align:left;font-size:0.75rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.5px;">ID</th>
                        <th style="padding:10px 12px;text-align:left;font-size:0.75rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.5px;">Thao tác</th>
                        <th style="padding:10px 12px;text-align:left;font-size:0.75rem;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.5px;">Chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model.Logs)
                    {
                        string actionClass = log.Action switch { "Create" => "action-create", "Update" => "action-update", "Delete" => "action-delete", _ => "action-update" };
                        string actionIcon  = log.Action switch { "Create" => "✨", "Update" => "✏️", "Delete" => "🗑️", _ => "📝" };
                        string actionLabel = log.Action switch { "Create" => "Tạo mới", "Update" => "Cập nhật", "Delete" => "Xóa", _ => log.Action };
                        string entityColor = log.EntityType switch { "Order" => "#00f2fe", "Customer" => "#a78bfa", "Product" => "#4ade80", _ => "var(--text-muted)" };
                        string entityLabel = log.EntityType switch { "Order" => "Đơn hàng", "Customer" => "Khách hàng", "Product" => "Sản phẩm", _ => log.EntityType };
                        string detailsLink = log.EntityType switch {
                            "Order" => $"/Orders/Logs?id={log.EntityId}",
                            _ => ""
                        };

                        <tr class="audit-row" style="border-bottom:1px solid rgba(255,255,255,0.04);">
                            <td style="padding:10px 12px;font-size:0.8rem;color:var(--text-muted);white-space:nowrap;">
                                @log.ChangedAt.ToLocalTime().ToString("dd/MM HH:mm:ss")
                            </td>
                            <td style="padding:10px 12px;">
                                <span style="font-size:0.8rem;font-weight:600;color:@entityColor;">@entityLabel</span>
                            </td>
                            <td style="padding:10px 12px;">
                                @if (!string.IsNullOrEmpty(detailsLink))
                                {
                                    <a href="@detailsLink" style="font-family:monospace;font-size:0.78rem;color:#00f2fe;text-decoration:none;" title="Xem log chi tiết">@log.EntityId</a>
                                }
                                else
                                {
                                    <code style="font-size:0.78rem;color:var(--text-color);">@log.EntityId</code>
                                }
                            </td>
                            <td style="padding:10px 12px;">
                                <span class="action-badge @actionClass">@actionIcon @actionLabel</span>
                            </td>
                            <td style="padding:10px 12px;">
                                @if (!string.IsNullOrEmpty(log.OldValues) || !string.IsNullOrEmpty(log.NewValues))
                                {
                                    <button class="btn-detail" onclick="toggleRow(this)" style="font-size:0.75rem;padding:4px 10px;">▶ Xem</button>
                                    <div class="row-detail hidden">
                                        @if (!string.IsNullOrEmpty(log.OldValues))
                                        {
                                            <div class="audit-val-block old" style="margin-top:8px;">
                                                <div class="val-label">Trước</div>
                                                <pre>@log.OldValues</pre>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(log.NewValues))
                                        {
                                            <div class="audit-val-block new" style="margin-top:8px;">
                                                <div class="val-label">Sau</div>
                                                <pre>@log.NewValues</pre>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span style="color:var(--text-muted);font-size:0.78rem;">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .audit-row:hover td { background: rgba(255,255,255,0.02); }

    .action-badge { font-size: 0.75rem; border-radius: 6px; padding: 3px 10px; font-weight: 600; }
    .action-badge.action-create { background: rgba(0,242,254,0.12); color: #00f2fe; border: 1px solid rgba(0,242,254,0.3); }
    .action-badge.action-update { background: rgba(247,151,30,0.12); color: #f7971e; border: 1px solid rgba(247,151,30,0.3); }
    .action-badge.action-delete { background: rgba(255,77,77,0.12); color: #ff4d4d; border: 1px solid rgba(255,77,77,0.3); }

    .btn-detail {
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.15s;
    }
    .btn-detail:hover { border-color: rgba(0,242,254,0.3); color: #00f2fe; }

    .row-detail.hidden { display: none; }

    .audit-val-block { border-radius: 8px; padding: 10px; overflow: auto; max-height: 180px; }
    .audit-val-block.old { background: rgba(255,77,77,0.06); border: 1px solid rgba(255,77,77,0.2); }
    .audit-val-block.new  { background: rgba(0,242,254,0.06); border: 1px solid rgba(0,242,254,0.2); }
    .val-label { font-size: 0.72rem; font-weight: 700; margin-bottom: 6px; text-transform: uppercase; letter-spacing: .5px; opacity: .7; }
    .audit-val-block.old .val-label { color: #ff4d4d; }
    .audit-val-block.new  .val-label { color: #00f2fe; }
    .audit-val-block pre { margin: 0; font-size: 0.72rem; font-family: monospace; color: var(--text-color); white-space: pre-wrap; word-break: break-all; }
</style>

<script>
function toggleRow(btn) {
    const detail = btn.nextElementSibling;
    const hidden = detail.classList.toggle('hidden');
    btn.textContent = hidden ? '▶ Xem' : '▼ Ẩn';
}
</script>
