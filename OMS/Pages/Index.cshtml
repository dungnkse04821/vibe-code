@page
@model IndexModel
@{
    ViewData["Title"] = "Bảng điều khiển OMS";
}

<div style="margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
    <div>
        <h1 class="page-title" style="margin: 0;">Bảng điều khiển</h1>
        <p style="color: var(--text-muted); margin: 4px 0 0 0; font-size: 0.95rem;">Chào mừng bạn quay trở lại hệ thống quản lý bán hàng OMS OMS</p>
    </div>
    <!-- Online status badge -->
    <div style="display: flex; align-items: center; gap: 8px; background: rgba(16, 185, 129, 0.08); padding: 8px 16px; border-radius: 50px; border: 1px solid rgba(16, 185, 129, 0.2); font-size: 0.85rem; color: #10b981; font-weight: 500;">
        <span style="width: 8px; height: 8px; border-radius: 50%; background: #10b981; display: inline-block; box-shadow: 0 0 8px #10b981; animation: pulse 2s infinite;"></span>
        Hệ thống hoạt động (PostgreSQL)
    </div>
</div>

<!-- Key Performance Indicators (KPIs) -->
<div class="stats-grid">
    <!-- Revenue -->
    <div class="glass-card stat-card">
        <div class="stat-icon primary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5h16.5M4.5 19.5h15M5.25 4.5v15m13.5-15v15M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 16.5h1.5M13.5 16.5H15" />
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-label">Doanh thu</span>
            <span class="stat-value" style="color: #ffffff;">@Model.TotalRevenue.ToString("N0") ₫</span>
        </div>
    </div>

    <!-- Deposits -->
    <div class="glass-card stat-card">
        <div class="stat-icon success">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-label">Tiền đặt cọc</span>
            <span class="stat-value" style="color: var(--success);">@Model.TotalDeposits.ToString("N0") ₫</span>
        </div>
    </div>

    <!-- Profit -->
    <div class="glass-card stat-card">
        <div class="stat-icon purple">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18l3.5-3.5 3 3 7-7 3 3 3.75-3.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-label">Lợi nhuận ước tính</span>
            <span class="stat-value" style="color: #00f2fe;">@Model.TotalProfit.ToString("N0") ₫</span>
        </div>
    </div>

    <!-- Total Orders -->
    <div class="glass-card stat-card">
        <div class="stat-icon warning">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
            </svg>
        </div>
        <div class="stat-info">
            <span class="stat-label">Tổng số đơn hàng</span>
            <span class="stat-value" style="color: var(--warning);">@Model.TotalOrders</span>
        </div>
    </div>
</div>

<!-- Main Dashboard Split Panel -->
<div class="grid-2" style="grid-template-columns: 2fr 1fr; gap: 24px;">
    <!-- Recent Orders -->
    <div class="glass-card">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h2 style="font-size: 1.2rem; font-weight: 600; margin: 0;">Top 5 đơn hàng mới nhất</h2>
            <a href="/Orders" style="color: #00f2fe; text-decoration: none; font-size: 0.85rem; font-weight: 500; display: inline-flex; align-items: center; gap: 4px;">
                Xem tất cả
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 14px; height: 14px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
            </a>
        </div>

        <!-- Desktop Mini Table -->
        <div class="d-none d-md-table table-responsive" style="width: 100%;">
            @if (Model.RecentOrders.Count == 0)
            {
                <div style="text-align: center; padding: 30px; color: var(--text-muted);">
                    Hệ thống chưa ghi nhận đơn hàng nào.
                </div>
            }
            else
            {
                <table class="custom-table" style="font-size: 0.85rem;">
                    <thead>
                        <tr>
                            <th>Mã ĐH</th>
                            <th>Khách hàng</th>
                            <th>Sản phẩm</th>
                            <th style="text-align: right;">Tổng tiền</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.RecentOrders)
                        {
                            string badgeClass = order.Status switch
                            {
                                "Chờ đặt" => "pending",
                                "Đã đặt" => "ordered",
                                "Đang về" => "shipping",
                                "Đã về" => "arrived",
                                "Đã giao" => "delivered",
                                "Hủy" => "cancelled",
                                _ => "pending"
                            };

                            <tr>
                                <td style="font-family: monospace; color: #00f2fe; font-weight: 600;">@order.Id</td>
                                <td style="font-weight: 600;">@order.CustomerName</td>
                                <td>@order.ProductName</td>
                                <td style="text-align: right; font-weight: 600;">@order.TotalAmount.ToString("N0") ₫</td>
                                <td>
                                    <span class="status-badge @badgeClass" style="padding: 4px 8px; font-size: 0.7rem;">@order.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <!-- Mobile Mini Cards -->
        <div class="d-md-none mobile-card-list">
            @if (Model.RecentOrders.Count == 0)
            {
                <div style="text-align: center; padding: 30px; color: var(--text-muted);">
                    Hệ thống chưa ghi nhận đơn hàng nào.
                </div>
            }
            else
            {
                @foreach (var order in Model.RecentOrders)
                {
                    string badgeClass = order.Status switch
                    {
                        "Chờ đặt" => "pending",
                        "Đã đặt" => "ordered",
                        "Đang về" => "shipping",
                        "Đã về" => "arrived",
                        "Đã giao" => "delivered",
                        "Hủy" => "cancelled",
                        _ => "pending"
                    };

                    <div class="mobile-data-card" style="padding: 12px; gap: 8px;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-family: monospace; color: #00f2fe; font-weight: bold;">@order.Id</span>
                            <span class="status-badge @badgeClass" style="padding: 2px 6px; font-size: 0.65rem;">@order.Status</span>
                        </div>
                        <div style="font-size: 0.8rem; display: flex; justify-content: space-between;">
                            <span style="font-weight: 600; color: #ffffff;">@order.CustomerName</span>
                            <span style="font-weight: 600; color: #ffffff;">@order.TotalAmount.ToString("N0") ₫</span>
                        </div>
                        <div style="font-size: 0.75rem; color: var(--text-muted);">
                            @order.ProductName
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Quick Navigation Actions -->
    <div class="glass-card" style="display: flex; flex-direction: column; justify-content: space-between;">
        <div>
            <h2 style="font-size: 1.2rem; font-weight: 600; margin-bottom: 20px;">Tổng quan Cơ sở dữ liệu</h2>
            
            <div style="display: flex; flex-direction: column; gap: 15px; margin-bottom: 25px;">
                <div style="display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); padding: 12px 16px; border-radius: 8px;">
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 20px; height: 20px; color: var(--success);">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.97 5.97 0 00-.75-2.906m-.173-4.059a3.5 3.5 0 11-8.823 0M18 9.098a3.5 3.5 0 11-7 0m-4.721 8.358a9.09 9.09 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.94 11.94 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.06 6.06 0 016 18.72m0-2.906a5.97 5.97 0 00-.75 2.906m-.173-4.059a3.5 3.5 0 11-8.823 0" />
                        </svg>
                        <span style="font-size: 0.9rem; font-weight: 500;">Khách hàng</span>
                    </div>
                    <strong style="color: var(--success);">@Model.TotalCustomers</strong>
                </div>

                <div style="display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); padding: 12px 16px; border-radius: 8px;">
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 20px; height: 20px; color: var(--primary);">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
                        </svg>
                        <span style="font-size: 0.9rem; font-weight: 500;">Danh mục SKU</span>
                    </div>
                    <strong style="color: var(--primary);">@Model.TotalProducts</strong>
                </div>
            </div>
        </div>

        <div>
            <h3 style="font-size: 0.95rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; margin-bottom: 12px;">Thao tác nhanh</h3>
            <div style="display: flex; flex-direction: column; gap: 10px;">
                <a href="/Orders/Create" class="btn-premium" style="justify-content: center; font-size: 0.88rem; padding: 10px 16px;">
                    Tạo đơn hàng mới
                </a>
                <a href="/Customers/Create" class="btn-secondary-premium" style="justify-content: center; font-size: 0.88rem; padding: 10px 16px;">
                    Thêm khách hàng
                </a>
                <a href="/Products/Create" class="btn-secondary-premium" style="justify-content: center; font-size: 0.88rem; padding: 10px 16px;">
                    Thêm sản phẩm
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        @@keyframes pulse {
            0% { transform: scale(0.9); opacity: 0.6; }
            50% { transform: scale(1.1); opacity: 1; box-shadow: 0 0 12px #10b981; }
            100% { transform: scale(0.9); opacity: 0.6; }
        }
        
        @@media (min-width: 768px) {
            .d-none { display: none !important; }
            .d-md-table { display: table !important; }
            .d-md-none { display: none !important; }
        }
        
        @@media (max-width: 767.98px) {
            .d-none { display: none !important; }
            .d-md-table { display: none !important; }
            .d-md-none { display: flex !important; }
            
            .grid-2 {
                grid-template-columns: 1fr !important;
                gap: 20px !important;
            }
        }
    </style>
}
