@page
@model OMS.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="glass-card">
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px; margin-bottom: 1.5rem;">
        <div>
            <h1 class="page-title">Quản lý Đơn hàng</h1>
            <p style="color: var(--text-muted); margin: 0; font-size: 0.9rem;">Theo dõi trạng thái, tính toán dòng tiền, lãi lỗ đơn hàng chi tiết</p>
        </div>
        <div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
            <!-- CSV Export Button -->
            <a id="btn-export-csv"
               href="/Orders/Export?@(string.Join("&", Model.StatusFilters.Select(s => "statusFilters=" + s)))&searchQuery=@(Model.SearchQuery ?? "")"
               class="btn-secondary-premium"
               style="padding: 10px 16px; display: inline-flex; align-items: center; gap: 8px; font-size: 0.875rem;">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:17px;height:17px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                </svg>
                Xuất CSV
            </a>
            <!-- Import Tracking button -->
            <a href="/Orders/ImportTracking"
               class="btn-secondary-premium"
               style="padding: 10px 16px; display: inline-flex; align-items: center; gap: 8px; font-size: 0.875rem;">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:17px;height:17px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 7.5m0 0L7.5 12M12 7.5V21" />
                </svg>
                Import Tracking
            </a>
            <a href="/Orders/Create" class="btn-premium">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 18px; height: 18px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Tạo đơn hàng mới
            </a>
        </div>
    </div>

    <!-- Quick Status Filters Widget -->
    <div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); margin-bottom: 24px; gap: 12px;">
        <a href="/Orders" class="glass-card stat-card" style="padding: 12px; text-decoration: none; cursor: pointer; transition: all 0.2s ease; border-color: @(!Model.StatusFilters.Any() ? "#00f2fe" : "var(--border-color)")">
            <div class="stat-info">
                <span class="stat-label" style="font-size: 0.75rem;">Tất cả</span>
                <span class="stat-value" style="font-size: 1.25rem;">@Model.TotalCount</span>
            </div>
        </a>
        <a href="/Orders?StatusFilters=Chờ đặt" class="glass-card stat-card" style="padding: 12px; text-decoration: none; cursor: pointer; transition: all 0.2s ease; border-color: @(Model.StatusFilters.Contains("Chờ đặt") ? "var(--warning)" : "var(--border-color)")">
            <div class="stat-info">
                <span class="stat-label" style="font-size: 0.75rem; color: var(--warning);">Chờ đặt</span>
                <span class="stat-value" style="font-size: 1.25rem; color: var(--warning);">@Model.PendingCount</span>
            </div>
        </a>
        <a href="/Orders?StatusFilters=Đã đặt" class="glass-card stat-card" style="padding: 12px; text-decoration: none; cursor: pointer; transition: all 0.2s ease; border-color: @(Model.StatusFilters.Contains("Đã đặt") ? "var(--purple)" : "var(--border-color)")">
            <div class="stat-info">
                <span class="stat-label" style="font-size: 0.75rem; color: var(--purple);">Đã đặt</span>
                <span class="stat-value" style="font-size: 1.25rem; color: var(--purple);">@Model.OrderedCount</span>
            </div>
        </a>
        <a href="/Orders?StatusFilters=Đang về" class="glass-card stat-card" style="padding: 12px; text-decoration: none; cursor: pointer; transition: all 0.2s ease; border-color: @(Model.StatusFilters.Contains("Đang về") ? "var(--info)" : "var(--border-color)")">
            <div class="stat-info">
                <span class="stat-label" style="font-size: 0.75rem; color: var(--info);">Đang về</span>
                <span class="stat-value" style="font-size: 1.25rem; color: var(--info);">@Model.ShippingCount</span>
            </div>
        </a>
        <a href="/Orders?StatusFilters=Đã về" class="glass-card stat-card" style="padding: 12px; text-decoration: none; cursor: pointer; transition: all 0.2s ease; border-color: @(Model.StatusFilters.Contains("Đã về") ? "#00f2fe" : "var(--border-color)")">
            <div class="stat-info">
                <span class="stat-label" style="font-size: 0.75rem; color: #00f2fe;">Đã về</span>
                <span class="stat-value" style="font-size: 1.25rem; color: #00f2fe;">@Model.ArrivedCount</span>
            </div>
        </a>
        <a href="/Orders?StatusFilters=Đã giao" class="glass-card stat-card" style="padding: 12px; text-decoration: none; cursor: pointer; transition: all 0.2s ease; border-color: @(Model.StatusFilters.Contains("Đã giao") ? "var(--success)" : "var(--border-color)")">
            <div class="stat-info">
                <span class="stat-label" style="font-size: 0.75rem; color: var(--success);">Đã giao</span>
                <span class="stat-value" style="font-size: 1.25rem; color: var(--success);">@Model.DeliveredCount</span>
            </div>
        </a>
        <a href="/Orders?StatusFilters=Hủy" class="glass-card stat-card" style="padding: 12px; text-decoration: none; cursor: pointer; transition: all 0.2s ease; border-color: @(Model.StatusFilters.Contains("Hủy") ? "var(--danger)" : "var(--border-color)")">
            <div class="stat-info">
                <span class="stat-label" style="font-size: 0.75rem; color: var(--danger);">Hủy</span>
                <span class="stat-value" style="font-size: 1.25rem; color: var(--danger);">@Model.CancelledCount</span>
            </div>
        </a>
    </div>

    <!-- Filter bar -->
    <form method="get" class="filter-bar" style="margin-bottom: 24px;">
        <div style="display: flex; gap: 10px; flex-wrap: wrap; width: 100%; align-items: flex-end;">
            <!-- Full-text Search -->
            <div class="filter-item" style="flex-grow: 2; min-width: 250px;">
                <label class="form-label" style="font-size: 0.75rem;">Tìm kiếm</label>
                <input type="text" asp-for="SearchQuery" class="form-input" placeholder="Từ khóa..." />
            </div>

            <!-- Date Range -->
            <div class="filter-item" style="flex-grow: 1;">
                <label class="form-label" style="font-size: 0.75rem;">Từ ngày</label>
                <input type="date" asp-for="FromDate" class="form-input" />
            </div>
            <div class="filter-item" style="flex-grow: 1;">
                <label class="form-label" style="font-size: 0.75rem;">Đến ngày</label>
                <input type="date" asp-for="ToDate" class="form-input" />
            </div>

            <!-- Multi-select Status -->
            <div class="filter-item" style="flex-grow: 1; min-width: 180px;">
                <label class="form-label" style="font-size: 0.75rem;">Trạng thái</label>
                <div class="oms-multiselect">
                    <button type="button" class="form-input oms-multiselect-btn" data-default="Tất cả trạng thái">
                        <span class="oms-multiselect-text">Tất cả trạng thái</span>
                    </button>
                    <div class="oms-multiselect-menu">
                        @foreach (var status in OMS.Models.OrderStatusList.All)
                        {
                            <label class="oms-multiselect-item">
                                <input type="checkbox" name="StatusFilters" value="@status" @(Model.StatusFilters.Contains(status) ? "checked" : "") />
                                @status
                            </label>
                        }
                    </div>
                </div>
            </div>

            <!-- Multi-select Carrier -->
            <div class="filter-item" style="flex-grow: 1; min-width: 180px;">
                <label class="form-label" style="font-size: 0.75rem;">Vận chuyển</label>
                <div class="oms-multiselect">
                    <button type="button" class="form-input oms-multiselect-btn" data-default="Tất cả HVC">
                        <span class="oms-multiselect-text">Tất cả HVC</span>
                    </button>
                    <div class="oms-multiselect-menu">
                        @foreach (var carrier in Model.Carriers)
                        {
                            <label class="oms-multiselect-item">
                                <input type="checkbox" name="CarrierFilters" value="@carrier.Name" @(Model.CarrierFilters.Contains(carrier.Name) ? "checked" : "") />
                                @carrier.Name
                            </label>
                        }
                    </div>
                </div>
            </div>

            <!-- Buttons -->
            <div class="filter-item" style="flex-grow: 0; display: flex; gap: 10px;">
                <button type="submit" class="btn-primary-premium" style="padding: 12px 20px;">Lọc</button>
                <a href="/Orders" class="btn-secondary-premium" style="padding: 12px 20px;" title="Xóa bộ lọc">Xóa</a>
            </div>
        </div>
    </form>

    <!-- Bulk Actions Toolbar (hidden by default, shown via JS) -->
    <form id="bulk-form" method="post" asp-page-handler="BulkUpdate" style="display:none; margin-bottom: 16px;">
        @Html.AntiForgeryToken()
        @foreach (var s in Model.StatusFilters) { <input type="hidden" name="StatusFilters" value="@s" /> }
        @foreach (var c in Model.CarrierFilters) { <input type="hidden" name="CarrierFilters" value="@c" /> }
        <input type="hidden" name="SearchQuery" value="@Model.SearchQuery" />
        <input type="hidden" name="FromDate" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" />
        <input type="hidden" name="ToDate" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" />
        <div class="bulk-toolbar" id="bulk-toolbar">
            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
                <span id="bulk-count-label" style="color: var(--text-muted); font-size: 0.875rem; white-space: nowrap;">
                    0 đơn được chọn
                </span>
                <button type="button" id="btn-select-all" class="btn-secondary-premium" style="padding: 7px 14px; font-size: 0.8rem;">
                    Chọn tất cả
                </button>
                <button type="button" id="btn-deselect-all" class="btn-secondary-premium" style="padding: 7px 14px; font-size: 0.8rem;">
                    Bỏ chọn
                </button>
                <select name="bulkStatus" id="bulk-status-select" class="form-input" style="padding: 8px 14px; min-width: 160px; width: auto;">
                    <option value="">-- Chọn trạng thái --</option>
                    <option value="Chờ đặt">Chờ đặt</option>
                    <option value="Đã đặt">Đã đặt</option>
                    <option value="Đang về">Đang về</option>
                    <option value="Đã về">Đã về</option>
                    <option value="Đã giao">Đã giao</option>
                    <option value="Hủy">Hủy</option>
                </select>
                <button type="submit" class="btn-premium" id="btn-bulk-apply" style="padding: 8px 18px; font-size: 0.875rem;" disabled>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:16px;height:16px;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    Áp dụng
                </button>
            </div>
        </div>
        <!-- Hidden checkboxes container for selected IDs -->
        <div id="bulk-selected-ids"></div>
    </form>

    <!-- Desktop View (Responsive Table) -->
    <div class="d-none d-md-table table-responsive" style="width: 100%;">
        @if (Model.Orders.Count == 0)
        {
            <div style="text-align: center; padding: 40px; color: var(--text-muted);">
                Không tìm thấy đơn hàng nào.
            </div>
        }
        else
        {
            <table class="custom-table" style="font-size: 0.88rem;">
                <thead>
                    <tr>
                        <th style="width: 40px;">
                            <label class="bulk-checkbox-wrapper" title="Chọn/bỏ tất cả">
                                <input type="checkbox" id="check-all-header" class="bulk-check-header" />
                                <span class="bulk-checkmark"></span>
                            </label>
                        </th>
                        <th>Mã ĐH</th>
                        <th>Ngày đặt</th>
                        <th>Khách hàng</th>
                        <th>Sản phẩm</th>
                        <th style="text-align: right;">SL</th>
                        <th style="text-align: right;">Giá bán</th>
                        <th style="text-align: right;">Tổng tiền</th>
                        <th style="text-align: right;">Đã cọc</th>
                        <th style="text-align: right;">Còn lại</th>
                        <th style="text-align: right;">Lãi</th>
                        <th>Vận chuyển</th>
                        <th>Trạng thái</th>
                        <th style="text-align: right;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        string badgeClass = order.Status switch
                        {
                            "Chờ đặt" => "pending",
                            "Đã đặt" => "ordered",
                            "Đang về" => "shipping",
                            "Đã về" => "arrived",
                            "Đã giao" => "delivered",
                            "Hủy" => "cancelled",
                            _ => "pending"
                        };

                        <tr class="bulk-row" data-id="@order.Id">
                            <td>
                                <label class="bulk-checkbox-wrapper">
                                    <input type="checkbox" class="bulk-check-row" value="@order.Id" />
                                    <span class="bulk-checkmark"></span>
                                </label>
                            </td>
                            <td style="font-family: monospace; color: #00f2fe; font-weight: 600;">@order.Id</td>
                            <td>@(order.OrderDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td>
                                <div style="font-weight: 600;">@order.CustomerName</div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);">@order.PhoneNumber</div>
                            </td>
                            <td>
                                <div style="font-weight: 600; color: #00f2fe; font-family: monospace; font-size: 0.8rem;">@order.Code</div>
                                <div>@order.ProductName</div>
                                @if (!string.IsNullOrEmpty(order.Color) || !string.IsNullOrEmpty(order.Size))
                                {
                                    <div style="font-size: 0.75rem; color: var(--text-muted);">
                                        @(order.Color ?? "-") / @(order.Size ?? "-")
                                    </div>
                                }
                            </td>
                            <td style="text-align: right;">@order.Quantity</td>
                            <td style="text-align: right;">@order.SellingPrice.ToString("N0") ₫</td>
                            <td style="text-align: right; font-weight: 600;">@order.TotalAmount.ToString("N0") ₫</td>
                            <td style="text-align: right; color: var(--success);">@order.Deposit.ToString("N0") ₫</td>
                            <td style="text-align: right; color: @(order.RemainingAmount > 0 ? "var(--warning)" : "var(--text-muted)"); font-weight: @(order.RemainingAmount > 0 ? "600" : "400");">
                                @order.RemainingAmount.ToString("N0") ₫
                            </td>
                            <td style="text-align: right; color: @(order.Profit >= 0 ? "#00f2fe" : "var(--danger)"); font-weight: 600;">
                                @order.Profit.ToString("N0") ₫
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(order.TrackingCode))
                                {
                                    <div style="font-size: 0.78rem;">
                                        @if (!string.IsNullOrEmpty(order.ShippingCarrier))
                                        {
                                            <div style="color: var(--text-muted); font-size: 0.72rem; margin-bottom: 2px;">@order.ShippingCarrier</div>
                                        }
                                        <div style="display:inline-flex;align-items:center;gap:5px;">
                                            <a href="#" onclick="trackOrder('@order.ShippingCarrier', '@order.TrackingCode'); return false;"
                                               style="color: #4facfe; font-family: monospace; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 4px;"
                                               title="Click để tra cứu vận đơn">
                                                @order.TrackingCode
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:12px;height:12px;flex-shrink:0;">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                                </svg>
                                            </a>
                                            <button type="button" class="action-btn" title="Sao chép mã vận đơn"
                                                    onclick="copyTracking('@order.TrackingCode')"
                                                    style="padding:3px;color:var(--text-muted);">
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:13px;height:13px;">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <span style="color: var(--text-muted); font-size: 0.78rem;">—</span>
                                }
                            </td>
                            <td>
                                <span class="status-badge @badgeClass">@order.Status</span>
                            </td>
                            <td>
                                <div class="action-btn-group" style="justify-content: flex-end;">
                                    <a href="/Orders/Print?id=@order.Id" class="action-btn" title="In hóa đơn" target="_blank" style="color: #4facfe;">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.074 48.074 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5zm-3 0h.008v.008H15V10.5z" />
                                        </svg>
                                    </a>
                                    <a href="/Orders/Logs?id=@order.Id" class="action-btn" title="Lịch sử" style="color: var(--text-muted);">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                    </a>
                                    <a href="/Orders/Edit?id=@order.Id" class="action-btn edit" title="Sửa">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
                                        </svg>
                                    </a>
                                    <a href="/Orders/Delete?id=@order.Id" class="action-btn delete" title="Xóa">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-1.8c0-.621-.504-1.125-1.125-1.125h-2.25c-.621 0-1.125.504-1.125 1.125v1.8M8.25 6.75h7.5" />
                                        </svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Mobile View (Responsive Cards List) -->
    <div class="d-md-none mobile-card-list">
        @if (Model.Orders.Count == 0)
        {
            <div style="text-align: center; padding: 40px; color: var(--text-muted);">
                Không tìm thấy đơn hàng nào.
            </div>
        }
        else
        {
            @foreach (var order in Model.Orders)
            {
                string badgeClass = order.Status switch
                {
                    "Chờ đặt" => "pending",
                    "Đã đặt" => "ordered",
                    "Đang về" => "shipping",
                    "Đã về" => "arrived",
                    "Đã giao" => "delivered",
                    "Hủy" => "cancelled",
                    _ => "pending"
                };

                <div class="mobile-data-card">
                    <div class="mobile-card-header">
                        <div style="display:flex; align-items:center; gap:10px;">
                            <label class="bulk-checkbox-wrapper">
                                <input type="checkbox" class="bulk-check-row" value="@order.Id" />
                                <span class="bulk-checkmark"></span>
                            </label>
                            <div>
                                <span class="mobile-card-title">@order.CustomerName</span>
                                <span style="font-size: 0.75rem; color: var(--text-muted); display: block;">@order.PhoneNumber</span>
                            </div>
                        </div>
                        <span class="status-badge @badgeClass">@order.Status</span>
                    </div>
                    <div class="mobile-card-body">
                        <div>
                            <span class="mobile-card-label">Mã đơn hàng:</span>
                            <span class="mobile-card-value" style="font-family: monospace;">@order.Id</span>
                        </div>
                        <div>
                            <span class="mobile-card-label">Ngày đặt:</span>
                            <span class="mobile-card-value">@(order.OrderDate?.ToString("dd/MM/yyyy") ?? "-")</span>
                        </div>
                        <div style="grid-column: span 2; background: rgba(0,0,0,0.15); padding: 8px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.03);">
                            <div style="font-weight: bold; color: #00f2fe; font-family: monospace;">@order.Code</div>
                            <div style="font-weight: 500; font-size: 0.85rem;">@order.ProductName</div>
                            <div style="font-size: 0.75rem; color: var(--text-muted);">Màu: @(order.Color ?? "-") | Size: @(order.Size ?? "-") | SL: @order.Quantity</div>
                        </div>
                        <div>
                            <span class="mobile-card-label">Tổng tiền:</span>
                            <span class="mobile-card-value" style="font-weight: bold;">@order.TotalAmount.ToString("N0") ₫</span>
                        </div>
                        <div>
                            <span class="mobile-card-label">Đã cọc:</span>
                            <span class="mobile-card-value" style="color: var(--success); font-weight: 500;">@order.Deposit.ToString("N0") ₫</span>
                        </div>
                        <div>
                            <span class="mobile-card-label">Còn lại:</span>
                            <span class="mobile-card-value" style="color: @(order.RemainingAmount > 0 ? "var(--warning)" : "var(--text-muted)"); font-weight: bold;">@order.RemainingAmount.ToString("N0") ₫</span>
                        </div>
                        <div>
                            <span class="mobile-card-label">Lợi nhuận:</span>
                            <span class="mobile-card-value" style="color: #00f2fe; font-weight: bold;">@order.Profit.ToString("N0") ₫</span>
                        </div>
                        @if (!string.IsNullOrEmpty(order.TrackingCode))
                        {
                            <div style="grid-column: span 2; background: rgba(79, 172, 254, 0.06); border: 1px solid rgba(79, 172, 254, 0.2); border-radius: 6px; padding: 8px; margin-top: 4px;">
                                <div style="font-size: 0.72rem; color: var(--text-muted); margin-bottom: 3px;">🚚 @(order.ShippingCarrier ?? "Vận chuyển")</div>
                                <a href="#" onclick="trackOrder('@order.ShippingCarrier', '@order.TrackingCode'); return false;"
                                   style="color: #4facfe; font-family: monospace; font-size: 0.85rem; font-weight: 700; text-decoration: none;">
                                    @order.TrackingCode ↗
                                </a>
                            </div>
                        }
                    </div>
                    <div class="mobile-card-actions">
                        @if (!string.IsNullOrEmpty(order.TrackingCode))
                        {
                            <a href="#" onclick="trackOrder('@order.ShippingCarrier', '@order.TrackingCode'); return false;" class="btn-secondary-premium" style="padding: 6px 12px; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 4px; color: #4facfe;">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 14px; height: 14px;">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                </svg>
                                Tra cứu
                            </a>
                        }
                        <a href="/Orders/Print?id=@order.Id" class="btn-secondary-premium" target="_blank" style="padding: 6px 12px; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 4px; color: #4facfe;">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 14px; height: 14px;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.074 48.074 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5zm-3 0h.008v.008H15V10.5z" />
                            </svg>
                            In HĐ
                        </a>
                        <a href="/Orders/Logs?id=@order.Id" class="btn-secondary-premium" style="padding: 6px 12px; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 4px;">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 14px; height: 14px;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            Lịch sử
                        </a>
                        <a href="/Orders/Edit?id=@order.Id" class="btn-secondary-premium" style="padding: 6px 12px; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 4px;">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 14px; height: 14px;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
                            </svg>
                            Sửa
                        </a>
                        <a href="/Orders/Delete?id=@order.Id" class="btn-danger-premium" style="padding: 6px 12px; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 4px;">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 14px; height: 14px;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-1.8c0-.621-.504-1.125-1.125-1.125h-2.25c-.621 0-1.125.504-1.125 1.125v1.8M8.25 6.75h7.5" />
                            </svg>
                            Xóa
                        </a>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="pagination-bar">
            <div class="pagination-info">
                Hiển thị <strong>@(((Model.CurrentPage - 1) * Model.PageSize) + 1)–@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalItems))</strong> / <strong>@Model.TotalItems</strong> đơn hàng
            </div>
            <div class="pagination-controls">
                @if (Model.CurrentPage > 1)
                {
                    <a href="@Model.BuildPageUrl(1)" class="page-btn" title="Trang đầu">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:14px;height:14px;"><path stroke-linecap="round" stroke-linejoin="round" d="M18.75 19.5l-7.5-7.5 7.5-7.5m-6 15L5.25 12l7.5-7.5" /></svg>
                    </a>
                    <a href="@Model.BuildPageUrl(Model.CurrentPage - 1)" class="page-btn" title="Trang trước">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:14px;height:14px;"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
                    </a>
                }

                @{
                    int windowSize = 5;
                    int startPage = Math.Max(1, Model.CurrentPage - windowSize / 2);
                    int endPage = Math.Min(Model.TotalPages, startPage + windowSize - 1);
                    if (endPage - startPage < windowSize - 1)
                    {
                        startPage = Math.Max(1, endPage - windowSize + 1);
                    }
                }

                @if (startPage > 1)
                {
                    <a href="@Model.BuildPageUrl(1)" class="page-btn">1</a>
                    @if (startPage > 2) { <span class="page-ellipsis">…</span> }
                }

                @for (int p = startPage; p <= endPage; p++)
                {
                    <a href="@Model.BuildPageUrl(p)" class="page-btn @(p == Model.CurrentPage ? "active" : "")">@p</a>
                }

                @if (endPage < Model.TotalPages)
                {
                    @if (endPage < Model.TotalPages - 1) { <span class="page-ellipsis">…</span> }
                    <a href="@Model.BuildPageUrl(Model.TotalPages)" class="page-btn">@Model.TotalPages</a>
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a href="@Model.BuildPageUrl(Model.CurrentPage + 1)" class="page-btn" title="Trang tiếp">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:14px;height:14px;"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
                    </a>
                    <a href="@Model.BuildPageUrl(Model.TotalPages)" class="page-btn" title="Trang cuối">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:14px;height:14px;"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 4.5l7.5 7.5-7.5 7.5m6-15l7.5 7.5-7.5 7.5" /></svg>
                    </a>
                }
            </div>
        </div>
    }
</div>

<style>
    @@media (min-width: 768px) {
        .d-none { display: none !important; }
        .d-md-table { display: table !important; }
        .d-md-none { display: none !important; }
    }
    @@media (max-width: 767.98px) {
        .d-none { display: none !important; }
        .d-md-table { display: none !important; }
        .d-md-none { display: flex !important; }
    }

    /* Bulk Actions Toolbar */
    .bulk-toolbar {
        background: rgba(0, 242, 254, 0.05);
        border: 1px solid rgba(0, 242, 254, 0.2);
        border-radius: 12px;
        padding: 12px 16px;
        animation: fadeSlideIn 0.2s ease;
    }
    @@keyframes fadeSlideIn {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* Custom checkbox */
    .bulk-checkbox-wrapper {
        display: inline-flex;
        align-items: center;
        cursor: pointer;
        position: relative;
        width: 18px;
        height: 18px;
    }
    .bulk-checkbox-wrapper input[type="checkbox"] {
        opacity: 0;
        width: 0;
        height: 0;
        position: absolute;
    }
    .bulk-checkmark {
        width: 18px;
        height: 18px;
        border: 2px solid rgba(0, 242, 254, 0.4);
        border-radius: 4px;
        background: rgba(255,255,255,0.04);
        display: inline-block;
        transition: all 0.15s ease;
        flex-shrink: 0;
    }
    .bulk-checkbox-wrapper input[type="checkbox"]:checked + .bulk-checkmark {
        background: linear-gradient(135deg, #00f2fe, #4facfe);
        border-color: #00f2fe;
    }
    .bulk-checkbox-wrapper input[type="checkbox"]:checked + .bulk-checkmark::after {
        content: '';
        display: block;
        width: 5px;
        height: 9px;
        border: 2px solid #000;
        border-top: none;
        border-left: none;
        transform: rotate(45deg) translate(2px, -1px);
    }

    /* Row selected highlight */
    .bulk-row.selected-row td {
        background: rgba(0, 242, 254, 0.04);
    }
</style>

<script>
(function () {
    const form = document.getElementById('bulk-form');
    const toolbar = document.getElementById('bulk-toolbar');
    const countLabel = document.getElementById('bulk-count-label');
    const selectedIdsContainer = document.getElementById('bulk-selected-ids');
    const btnSelectAll = document.getElementById('btn-select-all');
    const btnDeselectAll = document.getElementById('btn-deselect-all');
    const checkAllHeader = document.getElementById('check-all-header');
    const statusSelect = document.getElementById('bulk-status-select');
    const btnApply = document.getElementById('btn-bulk-apply');

    function getChecked() {
        return Array.from(document.querySelectorAll('.bulk-check-row:checked'));
    }

    function updateToolbar() {
        const checked = getChecked();
        const count = checked.length;

        if (count > 0) {
            form.style.display = 'block';
        } else {
            form.style.display = 'none';
        }

        countLabel.textContent = count + ' đơn được chọn';

        // Rebuild hidden inputs for selected IDs
        selectedIdsContainer.innerHTML = '';
        checked.forEach(function (cb) {
            const inp = document.createElement('input');
            inp.type = 'hidden';
            inp.name = 'selectedIds';
            inp.value = cb.value;
            selectedIdsContainer.appendChild(inp);
        });

        // Enable apply button only when status also selected
        btnApply.disabled = (count === 0 || !statusSelect.value);

        // Highlight rows
        document.querySelectorAll('.bulk-row').forEach(function (row) {
            const cb = row.querySelector('.bulk-check-row');
            if (cb && cb.checked) row.classList.add('selected-row');
            else row.classList.remove('selected-row');
        });
    }

    // Row checkbox change
    document.addEventListener('change', function (e) {
        if (e.target.classList.contains('bulk-check-row') || e.target.classList.contains('bulk-check-header')) {
            if (e.target.classList.contains('bulk-check-header') && checkAllHeader) {
                document.querySelectorAll('.bulk-check-row').forEach(function (cb) {
                    cb.checked = checkAllHeader.checked;
                });
            }
            updateToolbar();
        }
    });

    statusSelect && statusSelect.addEventListener('change', updateToolbar);

    btnSelectAll && btnSelectAll.addEventListener('click', function () {
        document.querySelectorAll('.bulk-check-row').forEach(function (cb) { cb.checked = true; });
        if (checkAllHeader) checkAllHeader.checked = true;
        updateToolbar();
    });

    btnDeselectAll && btnDeselectAll.addEventListener('click', function () {
        document.querySelectorAll('.bulk-check-row').forEach(function (cb) { cb.checked = false; });
        if (checkAllHeader) checkAllHeader.checked = false;
        updateToolbar();
    });

    // Prevent submit when no status selected
    form && form.addEventListener('submit', function (e) {
        if (!statusSelect.value) {
            e.preventDefault();
            statusSelect.focus();
            statusSelect.style.borderColor = 'var(--danger)';
            setTimeout(function () { statusSelect.style.borderColor = ''; }, 2000);
        }
    });
})();
</script>

<script>
// Shipping carrier tracking URL builder (used by inline onclick handlers in the table/cards)
const CARRIER_TRACKING_URLS_INDEX = {
    'GHTK': (code) => `https://i.ghtk.vn/${code}`,
    'GHN': (code) => `https://donhang.ghn.vn/?order_code=${code}`,
    'Viettel Post': (code) => `https://viettelpost.com.vn/tra-cuu-hanh-trinh-don/?billCode=${code}`,
    'Vietnam Post': (code) => `https://www.vnpost.vn/vi-vn/dinh-vi/buu-pham?key=${code}`,
    'J&T Express': (code) => `https://jtexpress.vn/tracking?bills=${code}`,
    'Best Express': (code) => `https://best-inc-vn.com/track?bills=${code}`,
    'Ninja Van': (code) => `https://www.ninjavan.co/vi-vn/tracking?id=${code}`,
    'SPX Express': (code) => `https://spx.vn/tracking/?trackingNumber=${code}`,
    'Lazada Logistics': (code) => `https://www.lazada.vn/order/${code}/`,
    'Tiki Now': (code) => `https://tiki.vn/tracking?orderCode=${code}`,
};

function trackOrder(carrier, code) {
    if (!code) return;
    const builder = CARRIER_TRACKING_URLS_INDEX[carrier];
    if (builder) {
        window.open(builder(code), '_blank');
    } else {
        window.open(`https://www.google.com/search?q=${encodeURIComponent(code + ' tracking')}`, '_blank');
    }
}

// Copy tracking code to clipboard
function copyTracking(code) {
    if (!code) return;
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(code).then(function () {
            OmsToast.success('Đã sao chép!', code);
        }).catch(function () {
            fallbackCopy(code);
        });
    } else {
        fallbackCopy(code);
    }
}

function fallbackCopy(text) {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;top:-9999px;left:-9999px;';
    document.body.appendChild(ta);
    ta.select();
    try {
        document.execCommand('copy');
        OmsToast.success('Đã sao chép!', text);
    } catch (e) {
        OmsToast.error('Không thể sao chép', 'Hãy copy thủ công: ' + text);
    }
    document.body.removeChild(ta);
}
</script>
