@page
@model OMS.Pages.Orders.CreateModel
@{
    ViewData["Title"] = "Tạo Đơn hàng mới";
}

<div class="glass-card" style="max-width: 1000px; margin: 0 auto;">
    <div class="mb-4">
        <h1 class="page-title">Tạo Đơn hàng mới</h1>
        <p style="color: var(--text-muted); margin: 0; font-size: 0.9rem;">Thiết lập đơn hàng mới. Chọn Khách hàng và Sản phẩm để tự động điền nhanh dữ liệu.</p>
    </div>

    <form method="post" id="order-form">
        <!-- 1. Chọn nhanh & Thông tin khách hàng -->
        <h3 style="color: #00f2fe; margin-bottom: 20px; font-size: 1.1rem; border-bottom: 1px solid rgba(0, 242, 254, 0.2); padding-bottom: 8px;">
            1. Khách hàng
        </h3>
        
        <div class="form-group">
            <label class="form-label">Chọn khách hàng có sẵn (Gõ để tìm kiếm)</label>
            <div class="autocomplete-container" id="customer-autocomplete">
                <input type="text" id="customer-search-input" class="form-input autocomplete-input" placeholder="Nhập tên hoặc số điện thoại..." autocomplete="off" />
                <div class="autocomplete-dropdown-list d-none" id="customer-dropdown-list"></div>
            </div>
        </div>

        <div class="grid-3">
            <div class="form-group">
                <label asp-for="Order.CustomerName" class="form-label"></label>
                <input asp-for="Order.CustomerName" id="order-customer-name" class="form-input" placeholder="Tên khách hàng..." />
                <span asp-validation-for="Order.CustomerName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Order.PhoneNumber" class="form-label"></label>
                <input asp-for="Order.PhoneNumber" id="order-phone" class="form-input" placeholder="Số điện thoại..." />
                <span asp-validation-for="Order.PhoneNumber" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Order.ShippingAddress" class="form-label"></label>
                <input asp-for="Order.ShippingAddress" id="order-address" class="form-input" placeholder="Địa chỉ giao hàng..." />
                <span asp-validation-for="Order.ShippingAddress" class="text-danger"></span>
            </div>
        </div>

        <!-- 2. Chọn nhanh & Thông tin sản phẩm -->
        <h3 style="color: #00f2fe; margin: 30px 0 20px 0; font-size: 1.1rem; border-bottom: 1px solid rgba(0, 242, 254, 0.2); padding-bottom: 8px;">
            2. Sản phẩm & Chi tiết
        </h3>

        <div class="form-group">
            <label class="form-label">Chọn sản phẩm có sẵn (Gõ để tìm kiếm theo tên hoặc SKU)</label>
            <div class="autocomplete-container" id="product-autocomplete">
                <input type="text" id="product-search-input" class="form-input autocomplete-input" placeholder="Nhập tên hoặc mã SKU sản phẩm..." autocomplete="off" />
                <div class="autocomplete-dropdown-list d-none" id="product-dropdown-list"></div>
            </div>
        </div>

        <div class="grid-3">
            <div class="form-group">
                <label asp-for="Order.Code" class="form-label"></label>
                <input asp-for="Order.Code" id="order-sku" class="form-input" placeholder="Mã SKU sản phẩm..." />
                <span asp-validation-for="Order.Code" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Order.ProductName" class="form-label"></label>
                <input asp-for="Order.ProductName" id="order-product-name" class="form-input" placeholder="Tên sản phẩm..." />
                <span asp-validation-for="Order.ProductName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Order.Category" class="form-label"></label>
                <input asp-for="Order.Category" id="order-category" class="form-input" placeholder="Danh mục..." />
                <span asp-validation-for="Order.Category" class="text-danger"></span>
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Order.Color" class="form-label"></label>
                <input asp-for="Order.Color" class="form-input" placeholder="Ví dụ: Đen, Trắng..." />
                <span asp-validation-for="Order.Color" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Order.Size" class="form-label"></label>
                <input asp-for="Order.Size" class="form-input" placeholder="Ví dụ: S, M, L, XL..." />
                <span asp-validation-for="Order.Size" class="text-danger"></span>
            </div>
        </div>

        <div class="grid-3">
            <div class="form-group">
                <label asp-for="Order.Source" class="form-label"></label>
                <input asp-for="Order.Source" id="order-source" class="form-input" placeholder="Nguồn hàng..." />
                <span asp-validation-for="Order.Source" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Order.Warehouse" class="form-label"></label>
                <input asp-for="Order.Warehouse" id="order-warehouse" class="form-input" placeholder="Kho hàng..." />
                <span asp-validation-for="Order.Warehouse" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Order.Status" class="form-label"></label>
                <select asp-for="Order.Status" class="form-input">
                    @foreach (var status in OMS.Models.OrderStatusList.All)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
                <span asp-validation-for="Order.Status" class="text-danger"></span>
            </div>
        </div>

        <!-- 3. Giá & Dòng tiền -->
        <h3 style="color: #00f2fe; margin: 30px 0 20px 0; font-size: 1.1rem; border-bottom: 1px solid rgba(0, 242, 254, 0.2); padding-bottom: 8px;">
            3. Dòng tiền & Định phí (Tự động tính toán)
        </h3>

        <div class="grid-3">
            <div class="form-group">
                <label asp-for="Order.SellingPrice" class="form-label"></label>
                <input asp-for="Order.SellingPrice" type="number" step="any" id="order-selling-price" class="form-input calc-trigger" placeholder="0" />
                <span asp-validation-for="Order.SellingPrice" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Order.Quantity" class="form-label"></label>
                <input asp-for="Order.Quantity" type="number" id="order-quantity" class="form-input calc-trigger" placeholder="1" />
                <span asp-validation-for="Order.Quantity" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Order.ImportPrice" class="form-label"></label>
                <input asp-for="Order.ImportPrice" type="number" step="any" id="order-import-price" class="form-input calc-trigger" placeholder="0" />
                <span asp-validation-for="Order.ImportPrice" class="text-danger"></span>
            </div>
        </div>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Order.Deposit" class="form-label"></label>
                <input asp-for="Order.Deposit" type="number" step="any" id="order-deposit" class="form-input calc-trigger" placeholder="0" />
                <span asp-validation-for="Order.Deposit" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Order.Discount" class="form-label"></label>
                <input asp-for="Order.Discount" type="number" step="any" id="order-discount" class="form-input calc-trigger" placeholder="0" />
                <span asp-validation-for="Order.Discount" class="text-danger"></span>
            </div>
        </div>

        <!-- Real-time dynamic calc results -->
        <div style="background: rgba(0, 242, 254, 0.04); border: 1px solid rgba(0, 242, 254, 0.15); border-radius: 12px; padding: 20px; margin-top: 24px;">
            <div class="grid-3" style="text-align: center;">
                <div>
                    <div style="color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase;">Tổng số tiền</div>
                    <div id="calc-total" style="font-size: 1.5rem; font-weight: 700; color: #ffffff; margin-top: 4px;">0 ₫</div>
                </div>
                <div>
                    <div style="color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase;">Còn lại phải thu</div>
                    <div id="calc-remaining" style="font-size: 1.5rem; font-weight: 700; color: var(--warning); margin-top: 4px;">0 ₫</div>
                </div>
                <div>
                    <div style="color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase;">Lợi nhuận dự tính</div>
                    <div id="calc-profit" style="font-size: 1.5rem; font-weight: 700; color: var(--success); margin-top: 4px;">0 ₫</div>
                </div>
            </div>
        </div>

        <!-- 4. Lịch trình -->
        <h3 style="color: #00f2fe; margin: 30px 0 20px 0; font-size: 1.1rem; border-bottom: 1px solid rgba(0, 242, 254, 0.2); padding-bottom: 8px;">
            4. Lịch trình & Giao nhận
        </h3>
        
        <div class="grid-3">
            <div class="form-group">
                <label asp-for="Order.OrderDate" class="form-label"></label>
                <input asp-for="Order.OrderDate" type="date" class="form-input" />
                <span asp-validation-for="Order.OrderDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Order.ArrivalDate" class="form-label"></label>
                <input asp-for="Order.ArrivalDate" type="date" class="form-input" />
                <span asp-validation-for="Order.ArrivalDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Order.PaymentDate" class="form-label"></label>
                <input asp-for="Order.PaymentDate" type="date" class="form-input" />
                <span asp-validation-for="Order.PaymentDate" class="text-danger"></span>
            </div>
        </div>

        <!-- 5. Vận chuyển -->
        <h3 style="color: #00f2fe; margin: 30px 0 20px 0; font-size: 1.1rem; border-bottom: 1px solid rgba(0, 242, 254, 0.2); padding-bottom: 8px;">
            5. Vận chuyển & Tra cứu đơn
        </h3>

        <div class="grid-2">
            <div class="form-group">
                <label asp-for="Order.ShippingCarrier" class="form-label"></label>
                <select asp-for="Order.ShippingCarrier" class="form-input" id="order-carrier">
                    <option value="">-- Chọn đơn vị vận chuyển --</option>
                    @foreach (var c in Model.Carriers)
                    {
                        <option value="@c.Name">@c.Name</option>
                    }
                </select>
                <span asp-validation-for="Order.ShippingCarrier" class="text-danger"></span>
                <div style="margin-top:6px;">
                    <a href="/Carriers" target="_blank" style="font-size:0.75rem;color:var(--text-muted);text-decoration:none;">
                        ⚙️ Quản lý đơn vị vận chuyển →
                    </a>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Order.TrackingCode" class="form-label"></label>
                <div style="position: relative; display:flex; gap:6px; align-items:center;">
                    <div style="position:relative;flex:1;">
                        <input asp-for="Order.TrackingCode" id="order-tracking-code" class="form-input" placeholder="Nhập mã vận đơn..." style="padding-right: 110px;" />
                        <button type="button" id="btn-track-preview" onclick="openTrackingUrl()" class="btn-secondary-premium"
                            style="position: absolute; right: 4px; top: 50%; transform: translateY(-50%); padding: 6px 12px; font-size: 0.78rem; border-radius: 6px;">
                            🔍 Tra cứu
                        </button>
                    </div>
                    <button type="button" onclick="copyTrackingForm()" class="btn-secondary-premium"
                            title="Sao chép mã vận đơn"
                            style="padding:11px 13px;border-radius:8px;flex-shrink:0;">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:16px;height:16px;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Order.TrackingCode" class="text-danger"></span>
            </div>
        </div>

        <!-- Form Submit & Cancel Actions -->
        <div style="display: flex; gap: 15px; justify-content: flex-end; margin-top: 40px; flex-wrap: wrap;">
            <a href="/Orders" class="btn-secondary-premium">
                Hủy
            </a>
            <button type="submit" class="btn-premium">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 18px; height: 18px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                Tạo đơn hàng
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Tracking URL builder - maps carrier name to their tracking search URL
        const CARRIER_TRACKING_URLS = {
            'GHTK': (code) => `https://i.ghtk.vn/${code}`,
            'GHN': (code) => `https://donhang.ghn.vn/?order_code=${code}`,
            'Viettel Post': (code) => `https://viettelpost.com.vn/tra-cuu-hanh-trinh-don/?billCode=${code}`,
            'Vietnam Post': (code) => `https://www.vnpost.vn/vi-vn/dinh-vi/buu-pham?key=${code}`,
            'J&T Express': (code) => `https://jtexpress.vn/tracking?bills=${code}`,
            'Best Express': (code) => `https://best-inc-vn.com/track?bills=${code}`,
            'Ninja Van': (code) => `https://www.ninjavan.co/vi-vn/tracking?id=${code}`,
            'SPX Express': (code) => `https://spx.vn/tracking/?trackingNumber=${code}`,
            'Lazada Logistics': (code) => `https://www.lazada.vn/order/${code}/`,
            'Tiki Now': (code) => `https://tiki.vn/tracking?orderCode=${code}`,
        };

        function openTrackingUrl() {
            const carrier = document.getElementById('order-carrier')?.value || '';
            const code = (document.getElementById('order-tracking-code')?.value || '').trim();
            if (!code) {
                OmsToast.warning('Thiếu mã', 'Vui lòng nhập Mã vận đơn trước khi tra cứu.');
                return;
            }
            const builder = CARRIER_TRACKING_URLS[carrier];
            if (builder) {
                window.open(builder(code), '_blank');
            } else {
                window.open(`https://www.google.com/search?q=${encodeURIComponent(code + ' tracking')}`, '_blank');
            }
        }

        function copyTrackingForm() {
            const code = (document.getElementById('order-tracking-code')?.value || '').trim();
            if (!code) { OmsToast.warning('Chưa có mã', 'Nhập mã vận đơn trước.'); return; }
            if (navigator.clipboard) {
                navigator.clipboard.writeText(code).then(() => OmsToast.success('Đã sao chép!', code));
            } else {
                const ta = Object.assign(document.createElement('textarea'), { value: code });
                ta.style.cssText = 'position:fixed;top:-9999px';
                document.body.appendChild(ta); ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
                OmsToast.success('Đã sao chép!', code);
            }
        }
    </script>

    <script>
        // Inject customer and product data from server model
        const customers = @Html.Raw(Model.CustomersJson);
        const products = @Html.Raw(Model.ProductsJson);

        function initAutocomplete({
            containerId,
            inputId,
            listId,
            data,
            searchFields,
            displayTemplate,
            displayValue,
            onSelect
        }) {
            const container = document.getElementById(containerId);
            const input = document.getElementById(inputId);
            const list = document.getElementById(listId);
            let activeIndex = -1;
            let filteredData = [];

            function renderList(items) {
                list.innerHTML = '';
                if (items.length === 0) {
                    const noResult = document.createElement('div');
                    noResult.className = 'autocomplete-item';
                    noResult.style.cursor = 'default';
                    noResult.style.color = 'var(--text-muted)';
                    noResult.innerText = 'Không tìm thấy kết quả';
                    list.appendChild(noResult);
                    return;
                }

                items.forEach((item, index) => {
                    const div = document.createElement('div');
                    div.className = 'autocomplete-item';
                    if (index === activeIndex) {
                        div.classList.add('active');
                    }
                    div.innerHTML = displayTemplate(item);
                    div.addEventListener('click', () => selectItem(item));
                    list.appendChild(div);
                });
            }

            function selectItem(item) {
                input.value = displayValue(item);
                onSelect(item);
                closeList();
            }

            function closeList() {
                list.classList.add('d-none');
                activeIndex = -1;
            }

            function showList() {
                list.classList.remove('d-none');
                filterItems(input.value);
            }

            function filterItems(query) {
                const q = query.trim().toLowerCase();
                if (!q) {
                    filteredData = data;
                } else {
                    filteredData = data.filter(item => {
                        return searchFields.some(field => {
                            const val = item[field];
                            return val && val.toString().toLowerCase().includes(q);
                        });
                    });
                }
                activeIndex = -1;
                renderList(filteredData);
            }

            input.addEventListener('focus', showList);

            input.addEventListener('input', () => {
                showList();
            });

            // Keyboard navigation
            input.addEventListener('keydown', (e) => {
                if (list.classList.contains('d-none')) {
                    if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
                        showList();
                        e.preventDefault();
                    }
                    return;
                }

                const items = list.querySelectorAll('.autocomplete-item');
                if (items.length === 0) return;

                if (e.key === 'ArrowDown') {
                    activeIndex = (activeIndex + 1) % filteredData.length;
                    renderList(filteredData);
                    scrollIntoView();
                    e.preventDefault();
                } else if (e.key === 'ArrowUp') {
                    activeIndex = (activeIndex - 1 + filteredData.length) % filteredData.length;
                    renderList(filteredData);
                    scrollIntoView();
                    e.preventDefault();
                } else if (e.key === 'Enter') {
                    if (activeIndex >= 0 && activeIndex < filteredData.length) {
                        selectItem(filteredData[activeIndex]);
                        e.preventDefault();
                    }
                } else if (e.key === 'Escape') {
                    closeList();
                    input.blur();
                    e.preventDefault();
                }
            });

            function scrollIntoView() {
                const activeEl = list.querySelector('.autocomplete-item.active');
                if (activeEl) {
                    activeEl.scrollIntoView({ block: 'nearest' });
                }
            }

            // Close when click outside
            document.addEventListener('click', (e) => {
                if (!container.contains(e.target)) {
                    closeList();
                }
            });
        }

        // Initialize autocompletes
        initAutocomplete({
            containerId: 'customer-autocomplete',
            inputId: 'customer-search-input',
            listId: 'customer-dropdown-list',
            data: customers,
            searchFields: ['FullName', 'PhoneNumber'],
            displayValue: (item) => `${item.FullName} (${item.PhoneNumber})`,
            displayTemplate: (item) => `
                <div class="item-title">${item.FullName}</div>
                <div class="item-subtitle">${item.PhoneNumber} | ${item.Address}</div>
            `,
            onSelect: (selected) => {
                document.getElementById('order-customer-name').value = selected.FullName;
                document.getElementById('order-phone').value = selected.PhoneNumber;
                document.getElementById('order-address').value = selected.Address;
            }
        });

        initAutocomplete({
            containerId: 'product-autocomplete',
            inputId: 'product-search-input',
            listId: 'product-dropdown-list',
            data: products,
            searchFields: ['Sku', 'Name'],
            displayValue: (item) => `${item.Sku} - ${item.Name}`,
            displayTemplate: (item) => `
                <div class="item-title">${item.Sku} - ${item.Name}</div>
                <div class="item-subtitle">Giá bán: ${new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(item.SellingPrice)} | Kho: ${item.Warehouse}</div>
            `,
            onSelect: (selected) => {
                document.getElementById('order-sku').value = selected.Sku;
                document.getElementById('order-product-name').value = selected.Name;
                document.getElementById('order-category').value = selected.Category;
                document.getElementById('order-source').value = selected.Source;
                document.getElementById('order-warehouse').value = selected.Warehouse;
                document.getElementById('order-selling-price').value = selected.SellingPrice;
                document.getElementById('order-import-price').value = selected.ImportPrice;
                
                calculateOrderFinance();
            }
        });

        // Financial Calculation Logic
        const calcTriggers = document.querySelectorAll('.calc-trigger');
        calcTriggers.forEach(input => {
            input.addEventListener('input', calculateOrderFinance);
        });

        function formatCurrency(val) {
            return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(val).replace('₫', '₫');
        }

        function calculateOrderFinance() {
            const sellingPrice = parseFloat(document.getElementById('order-selling-price').value) || 0;
            const quantity = parseInt(document.getElementById('order-quantity').value) || 0;
            const importPrice = parseFloat(document.getElementById('order-import-price').value) || 0;
            const deposit = parseFloat(document.getElementById('order-deposit').value) || 0;
            const discount = parseFloat(document.getElementById('order-discount').value) || 0;

            const totalAmount = sellingPrice * quantity;
            const remainingAmount = totalAmount - deposit - discount;
            const totalImportCost = importPrice * quantity;
            const profit = totalAmount - totalImportCost;

            document.getElementById('calc-total').innerText = formatCurrency(totalAmount);
            document.getElementById('calc-remaining').innerText = formatCurrency(remainingAmount);
            
            const profitEl = document.getElementById('calc-profit');
            profitEl.innerText = formatCurrency(profit);
            if (profit >= 0) {
                profitEl.style.color = 'var(--success)';
            } else {
                profitEl.style.color = 'var(--danger)';
            }
        }

        // Run calculation once on page load
        calculateOrderFinance();
    </script>
}
